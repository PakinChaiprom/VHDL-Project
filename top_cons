## Clock
set_property PACKAGE_PIN E3 [get_ports clk100MHZ]
set_property IOSTANDARD LVCMOS33 [get_ports clk100MHZ]
create_clock -period 10.000 -name sys_clk [get_ports clk100MHZ]

